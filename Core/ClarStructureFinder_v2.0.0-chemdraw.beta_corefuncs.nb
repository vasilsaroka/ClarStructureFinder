Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"listOfBondIndexes", "[", 
     RowBox[{"graph_", ",", "bondlength_", ",", "bondlengthdelta_"}], "]"}], ":=", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{"len", ",", "vcnums", ",", "nfun", ",", "listofbonds"}], 
       "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "graph", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"vcnums", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
           "graph", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], "\[Rule]",
            "i"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "len"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nfun", "=", 
        RowBox[{"Nearest", "[", "vcnums", "]"}]}], ";", "\[IndentingNewLine]",
        "\[IndentingNewLine]", 
       RowBox[{"listofbonds", "=", 
        RowBox[{"listOfBonds", "[", 
         RowBox[{"graph", ",", "bondlength", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1", ",", "1"}], "}"}], ",", "bondlengthdelta"}],
          "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"First", "@", 
            RowBox[{"nfun", "[", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
             "]"}]}], ",", 
           RowBox[{"First", "@", 
            RowBox[{"nfun", "[", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
             "]"}]}]}], "}"}], "&"}], "/@", "listofbonds"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], 
   RowBox[{"(*", " ", 
    RowBox[{"end", " ", "Block"}], " ", "*)"}], ";"}], 
  "\[IndentingNewLine]"}]], "Input",
 InitializationCell->True,
