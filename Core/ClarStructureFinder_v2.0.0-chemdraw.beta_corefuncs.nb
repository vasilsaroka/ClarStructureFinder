  3.9919458606216965`*^9}},ExpressionUUID->"a64aa000-baa0-4348-948a-\
8279725ad85e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"importCskeleton", "[", 
     RowBox[{"path_", ",", "plotrange_"}], "]"}], ":=", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
       "data", ",", "graph", ",", "\[IndentingNewLine]", "cntr1", ",", 
        "cntr2", ",", "sft"}], "\[IndentingNewLine]", "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Switch", "[", "\[IndentingNewLine]", "\t\t", 
        RowBox[{
         RowBox[{"ToLowerCase", "[", 
          RowBox[{"FileExtension", "[", "path", "]"}], "]"}], ",", 
         "\[IndentingNewLine]", "\t\t", "\"\<xyz\>\"", ",", 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{
          RowBox[{"data", "=", 
           RowBox[{"ReadList", "[", 
            RowBox[{"path", ",", "Word", ",", 
             RowBox[{"RecordLists", "\[Rule]", "True"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", "\t\t", 
          RowBox[{"data", "=", 
           RowBox[{"Drop", "[", 
            RowBox[{"data", ",", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
          "\t\t", 
          RowBox[{"graph", "=", 
           RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
               "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
               "===", "\"\<C\>\""}], ",", 
              RowBox[{
               RowBox[{"AppendTo", "[", 
                RowBox[{"graph", ",", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Read", "[", 
                    RowBox[{
                    RowBox[{"StringToStream", "[", "#", "]"}], ",", "Real"}], 
                    "]"}], "&"}], "/@", 
                  RowBox[{"Drop", "[", 
                   RowBox[{"#", ",", "1"}], "]"}]}]}], "]"}], ";", "#"}], ",",
               "#"}], "]"}], "&"}], "/@", "data"}]}], ",", 
         "\[IndentingNewLine]", "\t\t", "_", ",", "\[IndentingNewLine]", 
         "\t\t", 
         RowBox[{"(*", " ", 
          RowBox[{"cdxml", " ", "||", " ", "mol"}], " ", "*)"}], 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{"graph", "=", 
          RowBox[{"QuantityMagnitude", "[", 
           RowBox[{"AtomList", "[", 
            RowBox[{
             RowBox[{"Import", "[", "path", "]"}], ",", "\"\<C\>\"", 
             ",", "\"\<AtomCoordinates\>\""}], "]"}], "]"}]}]}], 
        "\[IndentingNewLine]", "]"}], 
       RowBox[{"(*", " ", 
        RowBox[{"end", " ", "Switch"}], " ", "*)"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "adjust", " ", "to", " ", "the", " ", "center", " ", "of", " ", "the",
          " ", "canvas"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"cntr1", "=", 
        FractionBox[
         RowBox[{"Total", "[", "graph", "]"}], 
         RowBox[{"Length", "[", "graph", "]"}]]}], ";", "\[IndentingNewLine]", 
       RowBox[{"cntr2", "=", 
        RowBox[{"Append", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "2"}], ")"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Plus", "@@", "#"}], "&"}], "/@", "plotrange"}], 
            ")"}]}], ",", "0"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sft", "=", 
        RowBox[{"cntr2", "-", "cntr1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "+", "sft"}], "&"}], "/@", "graph"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], 
   RowBox[{"(*", " ", 
    RowBox[{"end", " ", "Block"}], " ", "*)"}], ";"}], 
  "\[IndentingNewLine]"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.991945872763178*^9, 3.9919458739196796`*^9}, {
  3.993255984714775*^9, 
  3.993255990223158*^9}},ExpressionUUID->"d109e649-5dc3-c443-9976-\
905c53666529"]
}, Closed]],

Cell[CellGroupData[{

Cell["exportCXxyz", "Subsection",
 CellChangeTimes->{{3.991273534970991*^9, 3.991273545918089*^9}, {
