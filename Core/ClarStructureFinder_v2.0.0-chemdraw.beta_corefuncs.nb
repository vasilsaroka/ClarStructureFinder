Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"exportCXxyz", "[", 
    RowBox[{
    "graph_", ",", "CCbondlength_", ",", "CXbondlength_", ",", "Xlabel_", ",",
      "path_", ",", "tag_"}], "]"}], ":=", 
   RowBox[{"Block", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{"ln", ",", "rm1", ",", "rm2", ",", "dir", ",", 
       RowBox[{"delta", "=", "0.3"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Hatomspos", "=", 
        RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", "nnatoms", ",", "v",
        ",", "vec", ",", "vert", ",", "\[IndentingNewLine]", "v1", ",", "v2", 
       ",", "v3", ",", "\[IndentingNewLine]", "coords", ",", "firstline", ",",
        "secondline", ",", "\[IndentingNewLine]", "body", ",", "text", ",", 
       "str", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", "ps", ",", 
       "nd"}], "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", "subfunctions", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ps", "=", " ", 
       RowBox[{
        RowBox[{"Row", "[", 
         RowBox[{"#", ",", "\"\<\\t\>\""}], "]"}], "&"}]}], ";", 
      RowBox[{"(*", " ", 
       RowBox[{"parts", " ", "separation", " ", "function"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"nd", "=", 
       RowBox[{
        RowBox[{"PaddedForm", "[", 
         RowBox[{
          RowBox[{"1.0", " ", "#"}], ",", 
          RowBox[{"{", 
           RowBox[{"9", ",", "6"}], "}"}]}], "]"}], "&"}]}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{"number", " ", "display", " ", "function"}], " ", "*)"}], 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ln", "=", 
       RowBox[{"Length", "[", "graph", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rm1", "=", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         FractionBox["\[Pi]", "3"], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rm2", "=", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["\[Pi]", "3"]}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"v1", "=", 
       RowBox[{"CXbondlength", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           SqrtBox["3"], "/", "2"}], ",", 
          RowBox[{"1", "/", "2"}], ",", "0"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"v2", "=", 
       RowBox[{"CXbondlength", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            SqrtBox["3"]}], "/", "2"}], ",", 
          RowBox[{"1", "/", "2"}], ",", "0"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"v3", "=", 
       RowBox[{"CXbondlength", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", "\t", 
       RowBox[{
        RowBox[{
         RowBox[{"nnatoms", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"v", "=", 
             RowBox[{
              RowBox[{
              "graph", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}],
               "-", 
              RowBox[{
              "graph", "\[LeftDoubleBracket]", "j", 
               "\[RightDoubleBracket]"}]}]}], ";", "\[IndentingNewLine]", 
            "\t\t", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 SqrtBox[
                  RowBox[{"v", ".", "v"}]], "-", "CCbondlength"}], "]"}], "<",
                "delta"}], ",", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"nnatoms", ",", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "j", 
                 "\[RightDoubleBracket]"}]}], "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Length", "@", "nnatoms"}], ">", "2"}], ",", 
              RowBox[{"Break", "[", "]"}]}], "]"}]}], ",", 
           "\[IndentingNewLine]", "\t", 
           RowBox[{"{", 
            RowBox[{"j", ",", "ln"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\t", 
         RowBox[{"Switch", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{"Length", "@", "nnatoms"}], ",", "\[IndentingNewLine]", 
           "\t\t", "2", ",", "\[IndentingNewLine]", "\t\t", 
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                "nnatoms", "\[LeftDoubleBracket]", "1", 
                 "\[RightDoubleBracket]"}], "-", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}], "+", 
                RowBox[{
                "nnatoms", "\[LeftDoubleBracket]", "2", 
                 "\[RightDoubleBracket]"}], "-", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}]}], ")"}]}]}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{
                FractionBox["vec", 
                 SqrtBox[
                  RowBox[{"vec", ".", "vec"}]]], " ", "CXbondlength"}]}]}], 
             "]"}]}], ",", "\[IndentingNewLine]", "\t\t", "1", ",", 
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                "nnatoms", "\[LeftDoubleBracket]", "1", 
                 "\[RightDoubleBracket]"}], "-", 
                RowBox[{
                "graph", "\[LeftDoubleBracket]", "i", 
                 "\[RightDoubleBracket]"}]}], ")"}]}]}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  FractionBox["vec", 
                   SqrtBox[
                    RowBox[{"vec", ".", "vec"}]]], " ", "CXbondlength"}], 
                 ")"}], ".", " ", "rm1"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  FractionBox["vec", 
                   SqrtBox[
                    RowBox[{"vec", ".", "vec"}]]], " ", "CXbondlength"}], 
                 ")"}], ".", " ", "rm2"}]}]}], "]"}]}], ",", 
           "\[IndentingNewLine]", "\t\t", "0", ",", "\[IndentingNewLine]", 
           "\t\t", 
           RowBox[{
            RowBox[{"dir", "=", 
             RowBox[{"RandomChoice", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{"dir", " ", "v1"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{"dir", " ", "v2"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", "\t\t", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"Hatomspos", ",", 
              RowBox[{
               RowBox[{
               "graph", "\[LeftDoubleBracket]", "i", 
                "\[RightDoubleBracket]"}], "+", 
               RowBox[{"dir", " ", "v3"}]}]}], "]"}]}]}], 
          "\[IndentingNewLine]", "\t", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"i", ",", "ln"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]",
       "\[IndentingNewLine]", 
      StyleBox[
       RowBox[{"(*", " ", 
        RowBox[{"Export", " ", "to", " ", "text", " ", "file"}], " ", "*)"}],
       FontSize->16], 
      StyleBox["\[IndentingNewLine]",
       FontSize->16], 
      StyleBox[
       RowBox[{"(*", " ", 
        RowBox[{"coo", " ", "file", " ", "creation"}], " ", "*)"}],
       FontSize->16], 
      StyleBox["\[IndentingNewLine]",
       FontSize->16], "\[IndentingNewLine]", 
      RowBox[{"vert", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"ConstantArray", "[", 
            RowBox[{"\"\<C\>\"", ",", "ln"}], "]"}], ",", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"Xlabel", ",", 
             RowBox[{"Length", "@", "Hatomspos"}]}], "]"}]}], "}"}], ",", 
         "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"coords", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"graph", ",", "Hatomspos"}], "}"}], ",", "1"}], "]"}]}], ";",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"firstline", "=", 
       RowBox[{"ToString", "[", 
        RowBox[{
         RowBox[{"Length", "[", "graph", "]"}], "+", 
         RowBox[{"Length", "[", "Hatomspos", "]"}]}], "]"}]}], ";", 
      RowBox[{"(*", " ", 
       RowBox[{"number", " ", "of", " ", "atoms"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"secondline", "=", 
       RowBox[{"\"\<C\>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "graph", "]"}], "]"}], "<>", "Xlabel", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{"Length", "[", "Hatomspos", "]"}], "]"}], "<>", "tag"}]}], ";",
       " ", 
      RowBox[{"(*", " ", "comment", " ", "*)"}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"body", "=", 
       RowBox[{"ps", "/@", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
            "vert", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], ",", 
            RowBox[{"nd", "@", 
             RowBox[{"coords", "\[LeftDoubleBracket]", 
              RowBox[{"i", ",", "1"}], "\[RightDoubleBracket]"}]}], ",", 
            RowBox[{"nd", "@", 
             RowBox[{"coords", "\[LeftDoubleBracket]", 
              RowBox[{"i", ",", "2"}], "\[RightDoubleBracket]"}]}], ",", 
            RowBox[{"nd", "@", 
             RowBox[{"coords", "\[LeftDoubleBracket]", 
              RowBox[{"i", ",", "3"}], "\[RightDoubleBracket]"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "@", "coords"}]}], "}"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"text", "=", 
       RowBox[{"Flatten", "@", 
        RowBox[{"{", 
         RowBox[{"firstline", ",", "secondline", ",", "body"}], "}"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"str", "=", 
       RowBox[{"OpenWrite", "[", 
        RowBox[{"path", ",", 
         RowBox[{"FormatType", "\[Rule]", " ", "OutputForm"}], ",", 
         RowBox[{"CharacterEncoding", "\[Rule]", "\"\<ASCII\>\""}], ",", 
         RowBox[{"PageWidth", "\[Rule]", "Infinity"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"Write", "[", 
         RowBox[{"str", ",", 
          RowBox[{
          "text", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "@", "text"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Close", "[", "str", "]"}], ";"}]}], "\[IndentingNewLine]", 
    "]"}]}], 
  RowBox[{"(*", " ", 
   RowBox[{"end", " ", "Block"}], " ", "*)"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9912735985562153`*^9, 3.9912735999540977`*^9}, {
