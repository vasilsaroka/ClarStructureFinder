Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"mol2dViewPlot", "[", 
     RowBox[{"mol_", ",", "elec_", ",", "sizefactor_"}], "]"}], ":=", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", "\[IndentingNewLine]", "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"mol", "=!=", 
         RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"MoleculePlot", "[", 
         RowBox[{"mol", ",", "\[IndentingNewLine]", 
          RowBox[{"ColorRules", "->", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "->", 
               RowBox[{
               "colordata", "\[LeftDoubleBracket]", "2", 
                "\[RightDoubleBracket]"}]}], "&"}], "/@", "elec"}], ")"}]}], ",",
           "\[IndentingNewLine]", 
          RowBox[{"PlotTheme", "->", 
           RowBox[{"{", "\"\<ACS\>\"", "}"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"IncludeHydrogens", "->", "True"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"PlotRangePadding", "->", "None"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"ImageSize", "->", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"0.2", "+", 
              RowBox[{"0.72", " ", "sizefactor"}]}], ")"}], " ", 
            "imagesize"}]}]}], "\[IndentingNewLine]", "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Graphics", "[", 
         RowBox[{
          RowBox[{"{", "}"}], ",", 
          RowBox[{"ImageSize", "->", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"0.2", "+", 
              RowBox[{"0.72", " ", "sizefactor"}]}], ")"}], " ", 
            "imagesize"}]}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
     "\[IndentingNewLine]", "]"}]}], 
   RowBox[{"(*", " ", 
    RowBox[{"end", " ", "Block"}], " ", "*)"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
