Cell[CellGroupData[{

Cell["findAllClarStructures", "Subsection",
 CellChangeTimes->{{3.991273534970991*^9, 3.991273545918089*^9}, {
  3.9912735821846657`*^9, 3.991273585321928*^9}, {3.9919459463233376`*^9, 
  3.9919459514942665`*^9}},ExpressionUUID->"a45c779e-af0e-6246-abdf-\
63fa8fdc831d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"findAllClarStructures", "[", 
    RowBox[{"graph_", ",", "bondlength_", ",", "bondlengthdelta_"}], "]"}], ":=", 
   RowBox[{"Catch", "[", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
       "len", ",", " ", "vcnums", ",", "nfun", ",", "listofbonds", ",", 
        "\[IndentingNewLine]", "gedges", ",", "g", ",", "dg", ",", "gg", ",", 
        "vl", ",", "llen", ",", "\[IndentingNewLine]", "morethan3", ",", 
        "not6", ",", "not0", ",", "pos", ",", "\[IndentingNewLine]", 
        "sextetmaxnum", ",", "ivs", ",", "ies", ",", "ggg", ",", "ivslist", ",",
         "ieslist", ",", "\[IndentingNewLine]", "ucvrts", ",", "ucvrtlist", ",",
         "ucvrtcoords", ",", "ucvrtcoordlist", ",", "\[IndentingNewLine]", 
        "deficits", ",", "zerosextetsdata", ",", "chemistrydata"}], 
       "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "find", " ", "maximum", " ", "number", " ", "of", " ", "sextets"}], 
       " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "graph", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"vcnums", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
           "graph", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], "\[Rule]",
            "i"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "len"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nfun", "=", 
        RowBox[{"Nearest", "[", "vcnums", "]"}]}], ";", "\[IndentingNewLine]",
        "\[IndentingNewLine]", 
       RowBox[{"listofbonds", "=", 
        RowBox[{"listOfBonds", "[", 
         RowBox[{"graph", ",", "bondlength", ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "1", ",", "1"}], "}"}], ",", "bondlengthdelta"}],
          "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"gedges", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"First", "@", 
             RowBox[{"nfun", "[", 
              RowBox[{
              "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
              "]"}]}], "\[UndirectedEdge]", 
            RowBox[{"First", "@", 
             RowBox[{"nfun", "[", 
              RowBox[{
              "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
              "]"}]}]}], ")"}], "&"}], "/@", "listofbonds"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"Graph", "[", 
         RowBox[{
          RowBox[{"Range", "[", "len", "]"}], ",", "gedges", ",", " ", 
          RowBox[{"VertexCoordinates", "->", 
           RowBox[{"Most", "/@", "graph"}]}]}], " ", 
         RowBox[{"(*", 
          RowBox[{",", " ", 
           RowBox[{"GraphLayout", "->", 
            
            RowBox[{"\"\<TutteEmbedding\>\"", " ", "or", 
             " ", "\"\<PlanarEmbedding\>\""}]}]}], " ", "*)"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", "\t", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"PlanarGraphQ", "[", "g", "]"}]}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Throw", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", "}"}], ",", 
            RowBox[{"{", "}"}], ",", "Null", ",", 
            RowBox[{"{", "}"}]}], "}"}], "]"}]}], "\[IndentingNewLine]", 
        "]"}], 
       RowBox[{"(*", " ", 
        RowBox[{"end", " ", "If"}], " ", "*)"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "remove", " ", "vertices", " ", "with", " ", "degree", " ", "more", " ",
          "than", " ", "three", " ", "from", " ", "the", " ", "original", " ",
          "graph", " ", "because", " ", "they", " ", "cannot", " ", "be", " ",
          "a", " ", "part", " ", "of", " ", "a", " ", "sextet", " ", "due", " ",
          "to", " ", "carbon", " ", "atom", " ", "valency", " ", 
         "limination"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"morethan3", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"#", ">", "3"}], ")"}], "&"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pos", "=", 
        RowBox[{"Flatten", "@", 
         RowBox[{"Position", "[", 
          RowBox[{
           RowBox[{"VertexDegree", "[", "g", "]"}], ",", 
           RowBox[{"_Integer", "?", "morethan3"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"VertexDelete", "[", 
         RowBox[{"g", ",", 
          RowBox[{
           RowBox[{"VertexList", "[", "g", "]"}], "\[LeftDoubleBracket]", 
           "pos", "\[RightDoubleBracket]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"dg", "=", 
        RowBox[{"DualPlanarGraph", "[", "g", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"not6", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"#", "=!=", "6"}], ")"}], "&"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"If", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"LoopFreeGraphQ", "[", "dg", "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
