      "\[IndentingNewLine]", 
      RowBox[{"graph", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "len"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"vec", "=", 
          RowBox[{
           RowBox[{"vrtscoords", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "-", 
           RowBox[{"vrtscoords", "[", 
            RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
