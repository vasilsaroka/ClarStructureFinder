Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"listOfBonds", "[", 
    RowBox[{
    "unitcell_", ",", "bondlength_", ",", "projection_", ",", "delta_"}], 
    "]"}], ":=", 
   RowBox[{"Catch", "[", "\[IndentingNewLine]", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{"len", ",", "vec", ",", 
        RowBox[{"bondlist", "=", 
         RowBox[{"{", "}"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "unitcell", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Switch", "[", "\[IndentingNewLine]", "\t", 
        RowBox[{"projection", ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1", ",", "0"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"XY", "-", 
           RowBox[{"plane", " ", "projection"}]}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], "}"}]}],
                "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"{", 
          RowBox[{"1", ",", "0", ",", "1"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"XZ", "-", 
           RowBox[{"plane", " ", "projection"}]}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", "3"}], "}"}]}], "]"}], "]"}]}], "}"}]}],
                "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1", ",", "1"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"YZ", "-", 
           RowBox[{"plane", " ", "projection"}]}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", 
                    RowBox[{"{", 
                    RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", 
                    RowBox[{"j", ",", 
                    RowBox[{"{", 
                    RowBox[{"2", ",", "3"}], "}"}]}], "]"}], "]"}]}], "}"}]}],
                "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1", ",", "1"}], "}"}], 
         RowBox[{"(*", 
          RowBox[{"full", " ", "3", "D", " ", "space"}], "*)"}], ",", 
         "\[IndentingNewLine]", "\t", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"vec", "=", 
             RowBox[{
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "-", 
              RowBox[{"unitcell", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]",
             "\t\t", 
            RowBox[{"If", "[", "\[IndentingNewLine]", "\t\t\t", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"vec", ".", "vec"}], "]"}], "-", "bondlength"}], 
                "]"}], "<", "delta"}], ",", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"bondlist", ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], ",", 
                  RowBox[{"unitcell", "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], "}"}]}], "]"}]}], 
             RowBox[{"(*", 
              RowBox[{"end", " ", "AppendTo"}], "*)"}], "\[IndentingNewLine]",
              "\t\t", "]"}]}], 
           RowBox[{"(*", 
            RowBox[{"end", " ", "If"}], "*)"}], ",", "\[IndentingNewLine]", 
           "\t", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", 
             RowBox[{"len", "-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", 
             RowBox[{"i", "+", "1"}], ",", "len"}], "}"}]}], "]"}], 
         RowBox[{"(*", 
          RowBox[{"end", " ", "Do"}], "*)"}], ",", "\[IndentingNewLine]", 
         "\t", "_", ",", "\[IndentingNewLine]", "\t", 
         RowBox[{"Throw", "[", "$Failed", "]"}]}], "\[IndentingNewLine]", 
        "]"}], 
       RowBox[{"(*", 
        RowBox[{"end", " ", "Switch"}], "*)"}], ";", "\[IndentingNewLine]", 
       "bondlist"}]}], "\[IndentingNewLine]", "]"}], 
    RowBox[{"(*", 
     RowBox[{"end", " ", "Block"}], " ", "*)"}], "]"}]}], 
  RowBox[{"(*", 
   RowBox[{"end", " ", "Catch"}], "*)"}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9912735562894783`*^9, 3.991273557569229*^9}, {
